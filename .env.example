# ==========================================
# PREDICTIVE MAINTENANCE SYSTEM ENVIRONMENT TEMPLATE
# ==========================================

# Secret key configuration for session/flash protections
SECRET_KEY=change_this_secret_in_production

# Flask debug visibility configuration (True/False)
DEBUG=True

# SQLite Database connection URI
DATABASE_URI=sqlite:///instance/predictive_maintenance.db

# Dynamic logging parameters level configuration (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# Machine learning trained weights files paths configuration
MODEL_PATH=ml/models/trained_model.pkl
SCALER_PATH=ml/models/scaler.pkl

# Dynamic report serving storage directory configuration
REPORT_OUTPUT_PATH=outputs/reports
